#!/usr/bin/env bash
#MISE description="Generate third-party license documentation"

set -euo pipefail

FILEPATH="THIRD-PARTY-NOTICES.md"

echo "🔍 Scanning for backend dependencies (Go)..."
BACKEND_ROWS=$(cd backend && go-licenses csv ./... --ignore github.com/potibm  | sed 's/"//g' | awk -F, '{print "| " $1 " | [" $3 "](" $2 ") |"}')

echo "🔍 Scanning for frontend dependencies (NPM)..."
FRONTEND_ROWS=$(cd frontend && npx license-checker-rseidelsohn --excludePackages "tidsapparat" --csv | tail -n +2 | sed 's/"//g' | awk -F, '{print "| " $1 " | [" $2 "](" $3 ") |"}')

echo "🖨️ Writing to ${FILEPATH}..."
cat << EOF > "$FILEPATH"
# Third-Party Notices

This project is licensed under MIT. Below are the licenses of the dependencies used.

## Backend Dependencies (Go)

| Package | License |
| --- | --- |
$BACKEND_ROWS

## Frontend Dependencies (NPM)

| Package | License |
| --- | --- |
$FRONTEND_ROWS

## Assets

| Package | License |
| --- | --- |
| Logo Icon "Calendar Heart" by [Phosphor Icons](https://phosphoricons.com)  | [MIT](https://github.com/phosphor-icons/homepage/blob/master/LICENSE) |


EOF

echo "🔍 Formatting the generated file..."

npx --prefix frontend prettier --write "THIRD-PARTY-NOTICES.md"

echo "✅ Done!"
