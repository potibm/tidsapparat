#!/usr/bin/env bash
#MISE description="Setup Docker buildx builder (Internal)"
#MISE hide=true

set -e 

if ! docker buildx inspect tidsapparat-builder >/dev/null 2>&1; then
    echo "🔧 Creating buildx builder 'tidsapparat-builder'..."
    docker buildx create --name tidsapparat-builder --use --bootstrap
else
    echo "✅ Using existing buildx builder 'tidsapparat-builder'"
    docker buildx use tidsapparat-builder
    docker buildx inspect --bootstrap > /dev/null
fi